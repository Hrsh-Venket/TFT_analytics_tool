# Copy to .env and fill in real values. .env is gitignored.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tft_analytics
POSTGRES_USER=tft
POSTGRES_PASSWORD=change-me

# Dev keys expire every 24h. Production keys last longer.
# Get one at https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx

# OpenRouter key for the natural-language → TFTQuery feature.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# Optional model override; defaults to nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
